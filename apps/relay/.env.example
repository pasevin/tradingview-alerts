# Relay configuration. Copy to .env and fill in for hosted mode.
# Self-host (free) needs none of this — just REQUIRE_AUTH=false.

PORT=8787
PUBLIC_BASE_URL=http://localhost:8787
DB_PATH=./relay.db

# false = self-host (no accounts, unlimited). true = hosted (accounts + Pro).
REQUIRE_AUTH=false

# Magic-link email (hosted). Without a key, links are logged to stdout.
RESEND_API_KEY=
MAIL_FROM=TradingView Alerts <noreply@yourdomain.com>

# Stripe billing (hosted).
STRIPE_SECRET_KEY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_CONFIG_ID=

# Guards /admin/pro manual overrides.
ADMIN_SECRET=
