{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the menu-bar popover window.",
  "windows": ["popover"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:event:default",
    "notification:default",
    "process:allow-exit",
    "updater:default",
    "positioner:default"
  ]
}
